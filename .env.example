# =====================================================
# BuggyBooks – Environment Variable Reference
#
# Copy this file to .env and fill in your values.
# Never commit a real .env file to version control.
# =====================================================

# ----- Backend -----

# Secret key used to sign JWT access and refresh tokens.
# Must be a long, random, high-entropy string in production.
JWT_SECRET=replace-me-with-a-long-random-secret

# The port the Express backend listens on.
PORT=4000

# ----- Frontend (build-time) -----

# Base URL for the backend API. Injected at Vite build time.
# For local dev, this should point to the backend dev server.
VITE_API_URL=http://localhost:4000/api
